---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Eduard Ferré — Software & Data Engineer',
  description = "Eduard Ferré's developer hub — Software & Data Engineer building tools that actually work. Explore projects in web development, data engineering, and fintech.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://eduardferre.dev');
const ogImage = 'https://eduardferre.dev/og-image.png';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://eduardferre.dev/#person',
      name: 'Eduard Ferré',
      url: 'https://eduardferre.dev',
      jobTitle: 'Software & Data Engineer',
      image: 'https://eduardferre.dev/profile.png',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://eduardferre.dev/#website',
      name: 'Eduard Ferré — Developer Hub',
      url: 'https://eduardferre.dev',
      description,
      publisher: { '@id': 'https://eduardferre.dev/#person' },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#07070A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#F7F6F2" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Eduard Ferré" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Eduard Ferré — Developer Hub" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Eduard Ferré — Developer Hub" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Anti-flash: apply theme before first paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored ? stored === 'dark' : prefersDark) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Controls bar: language + theme toggles -->
    <div class="fixed top-4 right-4 z-50 flex items-center gap-2">

      <!-- Language toggle -->
      <button
        id="lang-toggle"
        aria-label="Switch language"
        class="h-9 px-3 rounded-full flex items-center justify-center transition-all duration-200
               bg-black/10 hover:bg-black/20 dark:bg-white/10 dark:hover:bg-white/20
               border border-black/10 dark:border-white/10 backdrop-blur-sm"
      >
        <span id="lang-label" class="font-mono text-[11px] font-bold tracking-widest"
              style="color: var(--text-muted)">ES</span>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200
               bg-black/10 hover:bg-black/20 dark:bg-white/10 dark:hover:bg-white/20
               border border-black/10 dark:border-white/10 backdrop-blur-sm"
      >
        <!-- Sun — shown in dark mode -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg"
             class="hidden dark:block w-4 h-4 text-yellow-300"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon — shown in light mode -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg"
             class="block dark:hidden w-4 h-4 text-slate-600"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <slot />

    <script>
      // ── Theme toggle ──────────────────────────────────
      document.getElementById('theme-toggle')!.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      // ── Language toggle ───────────────────────────────
      const TRANSLATIONS: Record<string, Record<string, string>> = {
        en: {
          tagline:          'Software & Data Engineer. Building tools that actually work.',
          section_projects: 'Projects',
          'desc-portfolio': 'Showcase of projects, skills and professional experience. Designed to tell a story, not just list technologies.',
          'desc-zenithfi':  'Financial app for personal investment management and real-time net worth tracking.',
        },
        es: {
          tagline:          'Software & Data Engineer. Construyendo herramientas que realmente funcionan.',
          section_projects: 'Proyectos',
          'desc-portfolio': 'Showcase de proyectos, habilidades y experiencia como desarrollador. Diseñado para contar una historia, no solo listar tecnologías.',
          'desc-zenithfi':  'App financiera para gestión de inversiones personales y seguimiento de patrimonio neto en tiempo real.',
        },
      };

      function applyLang(lang: string) {
        const t = TRANSLATIONS[lang];
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
          const key = el.dataset.i18n!;
          if (t[key] !== undefined) el.textContent = t[key];
        });
        (document.getElementById('lang-label') as HTMLElement).textContent =
          lang === 'en' ? 'ES' : 'EN';
        document.documentElement.lang = lang;
        localStorage.setItem('lang', lang);
      }

      // Apply saved language on load (default: 'en' — HTML is already in English)
      const savedLang = localStorage.getItem('lang') ?? 'en';
      if (savedLang !== 'en') applyLang(savedLang);

      document.getElementById('lang-toggle')!.addEventListener('click', () => {
        const current = localStorage.getItem('lang') ?? 'en';
        applyLang(current === 'en' ? 'es' : 'en');
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── CSS design tokens ─────────────────────────────── */
  :root {
    --bg:           #F7F6F2;
    --bg-card:      #FFFFFF;
    --bg-card-hover:#F2F1ED;
    --text-primary: #0F0F1A;
    --text-muted:   #6B6B8E;
    --text-faint:   #B8B8CC;
    --border:       rgba(15, 15, 26, 0.08);
    --border-hover: rgba(15, 15, 26, 0.16);
    --dot-color:    rgba(15, 15, 26, 0.06);
    --vignette:     rgba(247, 246, 242, 0.75);
    --accent:       #6D28D9;
    color-scheme: light;
  }

  html.dark {
    --bg:           #07070A;
    --bg-card:      #0D0D18;
    --bg-card-hover:#10101E;
    --text-primary: #E5E5F5;
    --text-muted:   #7A7A9E;
    --text-faint:   #30304A;
    --border:       rgba(255, 255, 255, 0.07);
    --border-hover: rgba(255, 255, 255, 0.14);
    --dot-color:    rgba(255, 255, 255, 0.07);
    --vignette:     rgba(7, 7, 10, 0.75);
    --accent:       #C8FF40;
    color-scheme: dark;
  }

  /* ── Base reset ────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background-color: var(--bg);
    color: var(--text-primary);
    font-family: 'Space Mono', Menlo, monospace;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  /* ── Atmospheric backgrounds ────────────────────────── */
  .dot-grid {
    background-image: radial-gradient(circle, var(--dot-color) 1px, transparent 1px);
    background-size: 26px 26px;
  }

  .vignette {
    background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 40%, var(--vignette) 100%);
  }

  /* ── Avatar frame — animated gradient border ────────── */
  @property --border-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  .avatar-frame {
    padding: 3px;
    border-radius: 1rem;
    background: conic-gradient(
      from var(--border-angle),
      #080810,
      #3B0764,
      #7C3AED,
      #C084FC,
      #7C3AED,
      #3B0764,
      #080810
    );
    animation: borderSweep 4s linear infinite;
  }

  @keyframes borderSweep {
    to { --border-angle: 360deg; }
  }

  /* ── Entrance animations ─────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  .animate-blink {
    animation: blink 1.1s step-end infinite;
  }
</style>
