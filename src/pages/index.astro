---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects.js';
---

<Layout>
  <!-- Atmospheric backgrounds -->
  <div class="dot-grid fixed inset-0 pointer-events-none" aria-hidden="true" />
  <div class="vignette fixed inset-0 pointer-events-none" aria-hidden="true" />

  <!-- Color aura blobs -->
  <div aria-hidden="true" class="fixed pointer-events-none overflow-hidden inset-0">
    <div class="absolute -top-32 -left-16 w-[480px] h-[480px] rounded-full
                bg-violet-500/[0.07] dark:bg-violet-500/[0.06] blur-[96px]" />
    <div class="absolute top-48 left-[45%] w-64 h-64 rounded-full
                bg-cyan-400/[0.06] dark:bg-cyan-400/[0.05] blur-[80px]" />
    <div class="absolute top-16 right-0 w-80 h-80 rounded-full
                bg-amber-400/[0.04] dark:bg-amber-400/[0.03] blur-[100px]" />
  </div>

  <main class="relative z-10 min-h-screen">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 py-16 md:py-28">

      <!-- ─── HERO ─────────────────────────────────────────────── -->
      <header class="mb-24">

        <!--
          Always flex-row: photo sits to the right of the title on ALL screen sizes.
          Title scales with viewport via clamp so both fit at 320px+.
        -->
        <div class="flex flex-row items-start justify-between gap-4 sm:gap-8 md:gap-12">

          <!-- Left: text content -->
          <div class="flex-1 min-w-0">
            <!-- Prompt -->
            <p
              class="font-mono text-[11px] tracking-[0.3em] uppercase mb-6 animate-fade-up"
              style="animation-delay: 0ms"
            >
              <span style="color: var(--text-faint)">$</span>
              <span style="color: var(--accent)"> whoami</span>
            </p>

            <!-- Name — clamp scales from ~29px on 320px to 96px on wide screens -->
            <h1
              class="font-display font-extrabold leading-[0.9] tracking-tight mb-6 animate-fade-up"
              style="animation-delay: 80ms"
            >
              <span class="block" style={`font-size: clamp(1.8rem, 8.5vw, 6rem); color: var(--text-primary)`}>Eduard</span>
              <span class="block" style={`font-size: clamp(1.8rem, 8.5vw, 6rem); color: var(--text-primary)`}>Ferré</span>
            </h1>

            <!-- Tagline -->
            <p
              class="font-mono text-[11px] sm:text-xs leading-relaxed animate-fade-up"
              style="color: var(--text-muted); animation-delay: 160ms"
            >
              <span data-i18n="tagline">Software &amp; Data Engineer. Building tools that actually work.</span><span
                class="animate-blink font-bold ml-px"
                style="color: var(--accent)"
              >_</span>
            </p>
          </div>

          <!-- Right: photo — smaller on mobile, grows on larger screens -->
          <div
            class="avatar-frame shrink-0 animate-fade-up
                   w-[96px] h-[96px] sm:w-44 sm:h-44 md:w-56 md:h-56"
            style="animation-delay: 40ms"
          >
            <div class="w-full h-full rounded-[13px] overflow-hidden">
              <img
                src="/profile.png"
                alt="Eduard Ferré"
                width="240"
                height="240"
                class="w-full h-full object-cover object-top"
              />
            </div>
          </div>

        </div>

        <!-- Divider -->
        <div
          class="flex items-center gap-5 mt-10 animate-fade-up"
          style="animation-delay: 260ms"
        >
          <div class="h-px flex-1" style="background: var(--border)" />
          <div class="flex items-center gap-4 font-mono text-[10px] tracking-widest uppercase"
               style="color: var(--text-faint)">
            <span>{projects.filter(p => p.status === 'live').length} live</span>
            <span>·</span>
            <span>eduardferre.dev</span>
          </div>
          <div class="h-px flex-1" style="background: var(--border)" />
        </div>
      </header>

      <!-- ─── PROJECTS ──────────────────────────────────────────── -->
      <section>
        <div
          class="flex items-center gap-3 mb-6 animate-fade-up"
          style="animation-delay: 340ms"
        >
          <span
            data-i18n="section_projects"
            class="font-mono text-[10px] tracking-[0.3em] uppercase"
            style="color: var(--text-faint)"
          >Projects</span>
          <div class="h-px w-8" style="background: var(--border)" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
          {projects.map((project, i) => (
            <ProjectCard project={project} index={i} />
          ))}
        </div>
      </section>

      <!-- ─── FOOTER ─────────────────────────────────────────────── -->
      <footer
        class="mt-28 flex items-center justify-between font-mono text-[10px] tracking-widest"
        style="color: var(--text-faint)"
      >
        <span>eduardferre.dev</span>
        <span>{new Date().getFullYear()}</span>
      </footer>
    </div>
  </main>
</Layout>
